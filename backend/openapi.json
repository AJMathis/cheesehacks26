{
  "openapi": "3.0.1",
  "info": {
    "title": "Calorie Calculator API",
    "version": "1.0.0",
    "description": "Calculate calories for listed food items using AI or a local fallback."
  },
  "paths": {
    "/calculate": {
      "post": {
        "summary": "Calculate calories",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "measurement": { "type": "string", "example": "g, cup, item" },
                        "quantity": { "type": "number" }
                      },
                      "required": ["name","measurement","quantity"]
                    }
                  }
                },
                "required": ["items"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Calculation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": { "type": "array" },
                    "totalCalories": { "type": "number" },
                    "model": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
